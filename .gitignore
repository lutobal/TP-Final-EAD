# Entorno virtual de Python (se recrea con "pip install -r requirements.txt")
backend/.venv/
backend/__pycache__/
__pycache__/
*.pyc

# Base de datos local: son datos de prueba, no código
backend/data/*.db

# Firmware (PlatformIO): cache de compilacion y config local del editor,
# se regeneran solos al abrir firmware/ como proyecto de PlatformIO
firmware/.pio/
firmware/.vscode/
.DS_Store
